# Copy the needed lines into your real local.properties (git-ignored).
# sdk.dir is written by Android Studio automatically.

# Supabase — from your project's API settings (Project Settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Gemini — create a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
